# Copy to .env on the VPS and fill in. NEVER commit the real .env.
MISANE_SECRET=generate-a-long-random-string
MISANE_DB=/var/www/misane-portal/backend/misane.db
MISANE_ORIGINS=https://app.misaneproperties.com

# First-run admin (Greg). Seeds an admin user on startup if it doesn't exist.
MISANE_ADMIN_EMAIL=greg@misaneproperties.com
MISANE_ADMIN_PASSWORD=set-a-strong-password

# Stripe (added in M4 — Greg creates these in his Stripe dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
