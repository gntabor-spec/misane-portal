# Copy to .env on the VPS and fill in. NEVER commit the real .env.
MISANE_SECRET=generate-a-long-random-string
MISANE_DB=/var/www/misane-portal/backend/misane.db
MISANE_ORIGINS=https://app.misaneproperties.com

# First-run admin (Greg). Seeds an admin user on startup if it doesn't exist.
MISANE_ADMIN_EMAIL=greg@misaneproperties.com
MISANE_ADMIN_PASSWORD=set-a-strong-password

# Email — domain mailbox SMTP (notifications + contact-form forwarding).
# Use your misaneproperties.com mailbox. Port 587 = STARTTLS, 465 = SSL.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=greg@misaneproperties.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=greg@misaneproperties.com
MISANE_APP_URL=https://app.misaneproperties.com

# Where files uploaded from the client Update tab are stored on the VPS.
MISANE_UPLOADS=/var/www/misane-portal/backend/uploads

# Stripe (added in M4 — Greg creates these in his Stripe dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
